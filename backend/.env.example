PORT=4000
NODE_ENV=development

# Local PostgreSQL (docker-compose)
DATABASE_URL=postgresql://tasktracker:tasktracker@localhost:5432/tasktracker?schema=public

# Prisma CLI (db push / migrate) — use same URL as DATABASE_URL locally
DIRECT_URL=postgresql://tasktracker:tasktracker@localhost:5432/tasktracker?schema=public

JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

FRONTEND_URL=http://localhost:3000

# Optional seed admin account (used by npm run db:seed)
ADMIN_EMAIL=admin@tasktracker.com
ADMIN_PASSWORD=admin12345
